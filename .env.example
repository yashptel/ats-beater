# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/custom_resume_dev

# AI
# Optional: used for integration smoke tests or local admin flows only.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_PRO_MODEL=gemini-3.1-pro-preview
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
USER_API_KEY_ENCRYPTION_KEY=generate-a-fernet-key-and-store-it-here

# Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
JWT_SECRET=your-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Storage
GCS_BUCKET=your-gcs-bucket-name
GCS_CREDENTIALS_PATH=credentials/gcs-service-account.json

# LaTeX
LATEX_BIN_PATH=/Library/TeX/texbin

# App
# ENVIRONMENT controls SSRF strictness for OpenAI-compatible base URLs:
# DEV/DEVELOPMENT/LOCAL/TEST allow local HTTP endpoints; any other value
# (e.g. PROD) enforces HTTPS-only and blocks localhost/private/loopback/link-local hosts.
ENVIRONMENT=DEV
FRONTEND_URL=http://localhost:8000
DEV_AUTH_BYPASS=false
